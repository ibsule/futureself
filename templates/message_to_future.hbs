<html>
  <head>
    <meta charset='utf-8' />
    <title>Message from the past</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet" />
  </head>

  <body style="margin: 0; padding: 0; background-color: #f5f0e8;">

    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding: 72px 24px;">

          <!-- Letter Container -->
          <table
            width="580"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="
              background: #fdfaf4;
              border: 1px solid #e0d8cc;
              font-family: 'EB Garamond', 'Georgia', 'Times New Roman', serif;
              color: #2e2b25;
            "
          >

            <!-- Top rule -->
            <tr>
              <td style="padding: 0;">
                <div style="height: 3px; background: #2e2b25;"></div>
              </td>
            </tr>

            <!-- Inner padding start -->
            <tr>
              <td style="padding: 56px 64px 64px 64px;">

                <table width="100%" cellpadding="0" cellspacing="0" border="0">

                  <!-- Header label -->
                  <tr>
                    <td style="text-align: center; padding-bottom: 32px;">
                      <span style="
                        font-family: 'EB Garamond', Georgia, serif;
                        font-size: 11px;
                        letter-spacing: 4px;
                        color: #9c8e78;
                        text-transform: uppercase;
                      ">A Message from Your Past</span>
                    </td>
                  </tr>

                  <!-- Thin rule -->
                  <tr>
                    <td style="text-align: center; padding-bottom: 32px;">
                      <div style="width: 40px; height: 1px; background: #c4b99a; margin: auto;"></div>
                    </td>
                  </tr>

                  <!-- Date -->
                  <tr>
                    <td style="text-align: center; padding-bottom: 20px;">
                      <span style="
                        font-family: 'EB Garamond', Georgia, serif;
                        font-size: 14px;
                        font-style: italic;
                        color: #8a7d68;
                        letter-spacing: 0.3px;
                      ">Written on {{writtenOn}}</span>
                    </td>
                  </tr>

                  <!-- Title -->
                  <tr>
                    <td style="text-align: center; padding-bottom: 40px;">
                      <h1 style="
                        margin: 0;
                        font-family: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
                        font-size: 34px;
                        font-weight: 300;
                        letter-spacing: 0.5px;
                        line-height: 1.3;
                        color: #2e2b25;
                      ">{{title}}</h1>
                    </td>
                  </tr>

                  <!-- Ornamental divider -->
                  <tr>
                    <td style="text-align: center; padding-bottom: 40px;">
                      <span style="
                        font-family: 'EB Garamond', Georgia, serif;
                        font-size: 18px;
                        color: #b0a48c;
                        letter-spacing: 12px;
                      ">&#10022; &#10022; &#10022;</span>
                    </td>
                  </tr>

                  <!-- Body content -->
                  <tr>
                    <td style="
                      font-family: 'EB Garamond', Georgia, serif;
                      font-size: 18px;
                      line-height: 1.9;
                      color: #2e2b25;
                      text-align: left;
                    ">
                      {{content}}
                    </td>
                  </tr>

                  <!-- Signature -->
                  <tr>
                    <td style="
                      padding-top: 52px;
                      font-family: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
                      font-size: 17px;
                      font-style: italic;
                      color: #6b5f4e;
                    ">
                      &mdash; {{senderName}}, your past self
                    </td>
                  </tr>

                  <!-- Footer rule + text -->
                  <tr>
                    <td style="padding-top: 56px;">
                      <div style="height: 1px; background: #d6cfc4; margin-bottom: 20px;"></div>
                      <p style="
                        margin: 0;
                        font-family: 'EB Garamond', Georgia, serif;
                        font-size: 12px;
                        letter-spacing: 3px;
                        color: #b0a48c;
                        text-align: center;
                        text-transform: uppercase;
                      ">Sent Across Time</p>
                    </td>
                  </tr>

                </table>

              </td>
            </tr>
            <!-- Inner padding end -->

            <!-- Bottom rule -->
            <tr>
              <td style="padding: 0;">
                <div style="height: 3px; background: #2e2b25;"></div>
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>
