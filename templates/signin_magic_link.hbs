<html>

  <head>
    <meta charset='utf-8' />
    <title>Magic Link | Future Self</title>
    <style>
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 30px 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        font-size: 14px;
      }
      .logo {
        text-align: center;
        margin-bottom: 30px;
      }
      .logo img {
        width: 100%;
      }
      .message {
        line-height: 1.6;
      }
      .button {
        display: inline-block;
        margin-top: 30px;
        background-color: #007bff;
        color: #ffffff;
        padding: 12px 24px;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
      }
      .footer {
        margin-top: 40px;
        color: #888888;
        font-size: 12px;
        text-align: center;
      }
      @media only screen and (max-width: 480px) {
        .container {
          padding: 15px;
        }
        .logo img {
          max-width: 100px;
        }
        .button {
          display: block;
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>

  <body>
    <div class='container'>
      <div class='logo'>
        <img src='' alt='' />
      </div>
      <div class='message'>
        <p>Hello {{name}},</p>
        <p>Use this code to sign in: <strong>{{signin_code}}</strong></p>
        <p>Alternatively, you can click on this
          <a href={{url}}>magic link</a>
          to sign in.</p>

        <p>Expires in 30 minutes. PLEASE DO NOT SHARE.</p>
      </div>
      <div class='footer'>
        <p>This email was sent by CairoBlocks. If you received this message in
          error, no further action is required.</p>
      </div>
    </div>
  </body>

</html>